import numpy as np
import matplotlib.pyplot as plt

#Входные данные
P2n = float(input("Мощность на валу - "))  # Мощность на валу [кВт]
Sn = float(input("Скольжение - "))   # Скольжение
p1n = float(input("Синхронная частота вращения - "))  # Синхронная частота вращения [об/мин]
eta_n = float(input("Коэффициент полезного действия - "))  # Коэффициент полезного действия
cos_phi_n = float(input("Коэффициент мощности обмотки статора - "))  # Коэффициент мощности обмотки статора

#Расчет характеристик
I_n = P2n / (np.sqrt(3) * 380 * cos_phi_n)  # Номинальный ток [А]
M_n = P2n * 1000 / (p1n * (1 - Sn))  # Номинальный момент [Нм]
M_p = M_n * 1.9  # Пусковой момент [Нм]
M_max = M_n * 2.9  # Максимальный вращающий момент [Нм]

#Расчет механической характеристики
M = np.linspace(0, M_max, 100)  # Диапазон моментов
n = (p1n * (1 - Sn)) / (2 * np.pi) * (1 - np.sqrt(1 - M / M_n))  # Частота вращения

#Построение графика механической характеристики
plt.plot(M, n)
plt.xlabel('Момент [Нм]')
plt.ylabel('Частота вращения [об/мин]')
plt.title('Механическая характеристика')
plt.grid(True)
plt.show()
